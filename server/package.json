{
  "name": "server",
  "version": "1.0.0",
  "description": "Production-ready Express and TypeScript backend for the customer feedback platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch . --ext ts --exec ts-node server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
